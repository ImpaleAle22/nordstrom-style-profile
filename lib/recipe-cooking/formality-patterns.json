{
  "patterns": [
    {
      "id": "modern-minimalist",
      "name": "Modern Minimalist",
      "description": "Tailored/dress pants + casual top + sneakers (tech executive, European streetwear)",
      "enabled": true,
      "rules": {
        "bottoms": {
          "minFormality": 4,
          "keywords": ["tailored", "dress pant", "dress trouser"]
        },
        "tops": {
          "maxFormality": 2,
          "keywords": ["t-shirt", "tee", "crewneck", "v-neck"]
        },
        "shoes": {
          "keywords": ["sneaker"]
        }
      }
    },
    {
      "id": "classic-smart-casual",
